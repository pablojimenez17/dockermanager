# ============================================================
# DockerManager - Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- MinIO (BÃ³veda de Backups interna) ---
# MinIO actÃºa como almacenamiento S3 donde se guardan las copias de seguridad.
# El backend se conecta a MinIO vÃ­a HAProxy usando el protocolo S3.
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD son las Ãºnicas credenciales necesarias.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Prometheus BasicAuth (htpasswd hash) ---
# Generate with: htpasswd -nb admin yourpassword | sed 's/\$/\$\$/g'
PROMETHEUS_BASICAUTH_USERS=admin:$$apr1$$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- EveBox BasicAuth (htpasswd hash) ---
# Generate with: htpasswd -nb admin yourpassword | sed 's/\$/\$\$/g'
EVEBOX_BASICAUTH_USERS=admin:$$apr1$$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
