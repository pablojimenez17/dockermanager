+        }
+        // Set some default ports if helpful
+        if (img.id === 'nginx') setPortBinding('8080:80');
+        if (img.id === 'mongo') setPortBinding('27017:27017');
+        if (img.id === 'wp-mysql') setPortBinding('8000:80');
+    };
+
+    const handleSubmit = async (e) => {
