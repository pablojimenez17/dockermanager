{
  "title": "Suricata IDS/IPS — Eventos de Red",
  "uid": "suricata-loki-main",
  "tags": [
    "suricata",
    "security",
    "loki"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "🚨 Alertas en las últimas 24h",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(count_over_time({job=\"suricata\", event_type=\"alert\"}[24h]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "📦 Total Eventos (6h)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": 0
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(count_over_time({job=\"suricata\"}[6h]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "🔒 Conexiones TLS",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(count_over_time({job=\"suricata\", event_type=\"tls\"}[6h]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "⚡ Alertas última hora",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": 0 }] }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum(count_over_time({job=\"suricata\", event_type=\"alert\"}[1h]))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "🚨 Alertas de Seguridad — IP origen → destino | Firma | Severidad",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "{job=\"suricata\", event_type=\"alert\"} | json | line_format \"🚨 {{.src_ip}}:{{.src_port}} → {{.dest_ip}}:{{.dest_port}}  |  {{.proto}}  |  Sev:{{.alert_severity}}  |  {{.alert_signature}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "📡 Volumen por tipo de evento",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 14,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum by (event_type) (count_over_time({job=\"suricata\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "🌐 Protocolos",
      "type": "piechart",
      "gridPos": {
        "x": 14,
        "y": 14,
        "w": 10,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "sum by (proto) (count_over_time({job=\"suricata\"}[6h]))",
          "refId": "A",
          "legendFormat": "{{proto}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "🔒 Eventos TLS — SNI | Versión | IP",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "{job=\"suricata\", event_type=\"tls\"} | json | line_format \"🔒 {{.src_ip}} → {{.tls_sni}}  |  {{.tls_version}}  |  {{.dest_ip}}:{{.dest_port}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "📋 Todos los Eventos — Tipo | IP origen → IP destino",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource}"
          },
          "expr": "{job=\"suricata\"} | json | line_format \"[{{.event_type}}]  {{.src_ip}}:{{.src_port}} → {{.dest_ip}}:{{.dest_port}}  |  {{.proto}}\"",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "label": "Loki Datasource",
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "schemaVersion": 38
}