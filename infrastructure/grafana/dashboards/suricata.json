{
  "title": "Suricata IDS/IPS — Eventos de Red",
  "uid": "suricata-loki-main",
  "tags": ["suricata", "security", "loki"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "🚨 Alertas de Seguridad en Tiempo Real",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"suricata\", event_type=\"alert\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "📊 Volumen de Eventos por Tipo (últimas 24h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (event_type) (count_over_time({job=\"suricata\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "🌐 Eventos por Protocolo",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (proto) (count_over_time({job=\"suricata\"}[24h]))",
          "refId": "A",
          "legendFormat": "{{proto}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "🔒 Eventos TLS",
      "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"suricata\", event_type=\"tls\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "📡 Todos los Eventos (Log Stream)",
      "type": "logs",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"suricata\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "label": "Loki Datasource",
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "schemaVersion": 38
}
