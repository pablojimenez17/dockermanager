{
  "title": "Docker Containers — cAdvisor",
  "uid": "cadvisor-containers",
  "tags": ["cadvisor", "docker", "containers", "prometheus"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "🐳 Contenedores activos",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "count(container_memory_usage_bytes{id=~\"/docker/.*\"})", "refId": "A", "instant": true }]
    },
    {
      "id": 2,
      "title": "🔥 CPU Total contenedores (%)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\"/docker/.*\"}[2m])) * 100", "refId": "A", "instant": true }]
    },
    {
      "id": 3,
      "title": "💾 RAM Total usada (contenedores)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 2000000000 }, { "color": "red", "value": 4000000000 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(container_memory_usage_bytes{id=~\"/docker/.*\"})", "refId": "A", "instant": true }]
    },
    {
      "id": 4,
      "title": "🌐 Red: Entrada total",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "fixed", "fixedColor": "purple" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": 0 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(container_network_receive_bytes_total{id=~\"/docker/.*\"}[2m]))", "refId": "A", "instant": true }]
    },
    {
      "id": 5,
      "title": "🔥 CPU por contenedor (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(container_cpu_usage_seconds_total{id=~\"/docker/.*\"}[2m]) * 100", "refId": "A", "legendFormat": "{{id}}" }]
    },
    {
      "id": 6,
      "title": "💾 RAM por contenedor",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "container_memory_usage_bytes{id=~\"/docker/.*\"}", "refId": "A", "legendFormat": "{{id}}" }]
    },
    {
      "id": 7,
      "title": "🌐 Red por contenedor (entrada)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(container_network_receive_bytes_total{id=~\"/docker/.*\"}[2m])", "refId": "A", "legendFormat": "{{id}}" }]
    },
    {
      "id": 8,
      "title": "📊 Top contenedores por RAM (actual)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "continuous-BlPu" } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "topk(10, container_memory_usage_bytes{id=~\"/docker/.*\"})", "refId": "A", "legendFormat": "{{id}}", "instant": true }]
    },
    {
      "id": 9,
      "title": "🔥 Top contenedores por CPU (actual)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "continuous-RdYlGr" } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "topk(10, rate(container_cpu_usage_seconds_total{id=~\"/docker/.*\"}[2m]) * 100)", "refId": "A", "legendFormat": "{{id}}", "instant": true }]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus Datasource",
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "schemaVersion": 38
}
